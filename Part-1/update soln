9. Bank Account (Dynamic Name/Type)
class Bank {
    char *name, *type; float bal;
public:
    Bank(const char* n, const char* t, float b) {
        int l1=0, l2=0; 
        while(n[l1]) l1++; while(t[l2]) l2++;
        name = new char[l1+1]; type = new char[l2+1];
        for(int i=0; i<=l1; i++) name[i] = n[i];
        for(int i=0; i<=l2; i++) type[i] = t[i];
        bal = b;
    }
    void show() { cout << name << " Bal: " << bal; }
    ~Bank() { delete[] name; delete[] type; }
};

