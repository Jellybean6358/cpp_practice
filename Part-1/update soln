18 & 20. Customer & Items (Deep Copy)
class Customer {
    char* CustomerName; Item* ItemsInterested;
public:
    Customer(const Customer &obj) {
        int l=0; while(obj.CustomerName[l]) l++;
        CustomerName = new char[l+1];
        for(int i=0; i<=l; i++) CustomerName[i] = obj.CustomerName[i];
        ItemsInterested = new Item(*obj.ItemsInterested); // Recursive deep copy
    }
    ~Customer() { delete[] CustomerName; delete ItemsInterested; }
};

