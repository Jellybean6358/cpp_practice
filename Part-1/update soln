#include <iostream>
using namespace std;

class Vehicle {
public:
    float mileage, price;
    Vehicle(float m, float p) : mileage(m), price(p) {}
};

class Car : public Vehicle {
public:
    float ownership_cost;
    int warranty, seating_capacity;
    char* fuel_type;

    Car(float m, float p, float oc, int w, int sc, const char* ft) 
        : Vehicle(m, p), ownership_cost(oc), warranty(w), seating_capacity(sc) {
        int l = 0; while(ft[l]) l++;
        fuel_type = new char[l+1];
        for(int i=0; i<=l; i++) fuel_type[i] = ft[i];
    }
    ~Car() { delete[] fuel_type; }
};

class Audi : public Car {
    char* model_type;
public:
    Audi(float m, float p, float oc, int w, int sc, const char* ft, const char* mt)
        : Car(m, p, oc, w, sc, ft) {
        int l = 0; while(mt[l]) l++;
        model_type = new char[l+1];
        for(int i=0; i<=l; i++) model_type[i] = mt[i];
    }
    void print() {
        cout << "Audi Model: " << model_type << " | Price: " << price 
             << " | Mileage: " << mileage << " | Fuel: " << fuel_type << endl;
    }
    ~Audi() { delete[] model_type; }
};

