6. Electricity Bill (Dynamic Name)
class EBill {
    int cno; char* name; float units;
public:
    EBill(const char* n, int c, float u) {
        int len = 0; while(n[len]) len++;
        name = new char[len + 1];
        for(int i=0; i<=len; i++) name[i] = n[i];
        cno = c; units = u;
    }
    void calculate() { cout << name << " Bill: " << units * 5; }
    ~EBill() { delete[] name; }
};

