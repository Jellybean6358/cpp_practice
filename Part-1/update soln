#include <iostream>
using namespace std;

class Vehicle {
public:
    float mileage, price;
    Vehicle(float m, float p) : mileage(m), price(p) {}
};

class Car : public Vehicle {
public:
    float ownership_cost;
    int warranty, seating_capacity;
    char* fuel_type;

    Car(float m, float p, float oc, int w, int sc, const char* ft) 
        : Vehicle(m, p), ownership_cost(oc), warranty(w), seating_capacity(sc) {
        int l = 0; while(ft[l]) l++;
        fuel_type = new char[l+1];
        for(int i=0; i<=l; i++) fuel_type[i] = ft[i];
    }
    ~Car() { delete[] fuel_type; }
};

class Audi : public Car {
    char* model_type;
public:
    Audi(float m, float p, float oc, int w, int sc, const char* ft, const char* mt)
        : Car(m, p, oc, w, sc, ft) {
        int l = 0; while(mt[l]) l++;
        model_type = new char[l+1];
        for(int i=0; i<=l; i++) model_type[i] = mt[i];
    }
    void print() {
        cout << "Audi Model: " << model_type << " | Price: " << price 
             << " | Mileage: " << mileage << " | Fuel: " << fuel_type << endl;
    }
    ~Audi() { delete[] model_type; }
};

class Bike : public Vehicle {
public:
    int cylinders, gears;
    char *cooling, *wheel;
    Bike(float m, float p, int c, int g, const char* co, const char* wh) 
        : Vehicle(m, p), cylinders(c), gears(g) {
        // Manual heap allocation for cooling and wheel strings...
    }
};

class Bajaj : public Bike {
    char* make_type;
public:
    Bajaj(float m, float p, int c, int g, const char* co, const char* wh, const char* mk)
        : Bike(m, p, c, g, co, wh) {
        int l = 0; while(mk[l]) l++;
        make_type = new char[l+1];
        for(int i=0; i<=l; i++) make_type[i] = mk[i];
    }
    void print() { cout << "Bajaj Make: " << make_type << " | Price: " << price << endl; }
    ~Bajaj() { delete[] make_type; }
};

int main() {
    Audi a(15.5, 5000000, 200000, 5, 5, "Diesel", "A4");
    a.print();
    
    Bajaj b(45.0, 150000, 1, 5, "Air", "Alloys", "Pulsar");
    b.print();
    return 0;
}
